{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=student-petitions.db"
  },
  "Jwt": {
    "Issuer": "StudentPetitions.Api",
    "Audience": "StudentPetitions.Api",
    "Key": "THIS_IS_A_DEVELOPMENT_ONLY_SECRET_KEY_FOR_STUDENT_PETITIONS_API",
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/student-petitions-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "StudentPetitions.Api"
    }
  },
  "AllowedHosts": "*"
}
