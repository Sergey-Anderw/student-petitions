{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=student-petitions.db"
  },
  "Jwt": {
    "Issuer": "StudentPetitions.Api",
    "Audience": "StudentPetitions.Api",
    "Key": "THIS_IS_A_DEVELOPMENT_ONLY_SECRET_KEY_FOR_STUDENT_PETITIONS_API",
    "ExpirationMinutes": 60,
    "StudentUserId": "11111111-1111-1111-1111-111111111111"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/student-petitions-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
